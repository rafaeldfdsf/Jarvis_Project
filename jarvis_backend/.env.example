OPENAI_API_KEY=your-openai-key
JARVIS_API_TOKEN=change-me
JARVIS_LOG_LEVEL=INFO
JARVIS_OLLAMA_URL=http://127.0.0.1:11434
JARVIS_OLLAMA_MODEL=llama3.1:8b
JARVIS_OPENAI_CHAT_MODEL=gpt-4.1-mini
JARVIS_DB_FILE=memory.db
JARVIS_MAX_TURNS=6
JARVIS_LLM_TIMEOUT_SECONDS=60
JARVIS_WEATHER_TIMEOUT_SECONDS=10
JARVIS_OPENAI_TIMEOUT_SECONDS=45
JARVIS_OPENAI_STT_MODEL=whisper-1
JARVIS_OPENAI_TTS_MODEL=gpt-4o-mini-tts
JARVIS_OPENAI_TTS_VOICE=cedar
